<Window x:Class="GreenMart.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="GreenMart - Đăng nhập" Height="500" Width="800"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    
    <Border CornerRadius="20" Background="White" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.3" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Banner -->
            <Border Background="#1B5E20">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="Storefront" Width="100" Height="100" Foreground="#A5D6A7" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="GREEN MART" FontSize="36" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Hệ thống quản lý chuyên nghiệp" FontSize="16" Foreground="#A5D6A7" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Right Login Form -->
            <Grid Grid.Column="1" Margin="40">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Đăng nhập" FontSize="28" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,40" HorizontalAlignment="Center"/>
                    
                    <TextBox x:Name="txtUsername" materialDesign:HintAssist.Hint="Tên đăng nhập" 
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                             FontSize="16" Margin="0,0,0,25" Height="50"/>
                             
                    <PasswordBox x:Name="txtPassword" materialDesign:HintAssist.Hint="Mật khẩu" 
                                 Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" 
                                 FontSize="16" Margin="0,0,0,10" Height="50" KeyDown="txtPassword_KeyDown"/>
                    
                    <TextBlock x:Name="txtError" Text="" Foreground="#E53935" FontSize="13" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                    
                    <Button Content="ĐĂNG NHẬP" Background="#4CAF50" Foreground="White" BorderThickness="0" 
                            Height="50" FontSize="16" FontWeight="Bold" materialDesign:ButtonAssist.CornerRadius="10" Click="btnLogin_Click"/>
                </StackPanel>
                
                <Button Style="{StaticResource MaterialDesignIconButton}" VerticalAlignment="Top" HorizontalAlignment="Right"
                        Foreground="#95A5A6" Width="30" Height="30" Margin="0,-20,-20,0" Click="btnExit_Click">
                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
