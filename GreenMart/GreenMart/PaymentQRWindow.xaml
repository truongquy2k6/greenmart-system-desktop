<Window x:Class="GreenMart.PaymentQRWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Thanh toán chuyển khoản VietQR" Height="650" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" Background="Transparent" AllowsTransparency="True">

    <materialDesign:Card UniformCornerRadius="16" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="#1B5E20" CornerRadius="16,16,0,0" Padding="20">
                <Grid>
                    <TextBlock Text="MÃ QR THANH TOÁN" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <Button Style="{StaticResource MaterialDesignIconButton}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,-10,-10,0" Foreground="White" Click="btnDong_Click">
                        <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="20" HorizontalAlignment="Center">
                <TextBlock Text="Vui lòng quét mã QR dưới đây bằng ứng dụng ngân hàng để thanh toán" FontSize="13" Foreground="#7F8C8D" TextAlignment="Center" Margin="0,0,0,15" TextWrapping="Wrap"/>
                
                <Border Width="300" Height="380" Background="#F8F9FA" CornerRadius="10" BorderBrush="#EEEEEE" BorderThickness="1">
                    <Grid>
                        <!-- Thêm icon loading trong lúc chờ tải ảnh -->
                        <ProgressBar x:Name="loadingProgress" Style="{StaticResource MaterialDesignCircularProgressBar}" Value="0" IsIndeterminate="True" HorizontalAlignment="Center" VerticalAlignment="Center" Width="40" Height="40" Foreground="#1B5E20"/>
                        <Image x:Name="imgQR" Stretch="Uniform" Margin="10"/>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock Text="Số tiền: " FontSize="16" Foreground="#2C3E50" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtAmount" Text="0 đ" FontSize="18" Foreground="#E65100" FontWeight="Black"/>
                </StackPanel>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="0,0,16,16" Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Hủy bỏ" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#E74C3C" BorderBrush="#E74C3C" Height="45" Margin="0,0,10,0" Click="btnDong_Click"/>
                    <Button Grid.Column="1" Content="ĐÃ NHẬN TIỀN" Background="#4CAF50" BorderThickness="0" Height="45" FontWeight="Bold" Click="btnDaNhan_Click"/>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</Window>
