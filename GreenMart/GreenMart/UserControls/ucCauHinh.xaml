<UserControl x:Class="GreenMart.UserControls.ucCauHinh"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Cấu hình hệ thống" FontSize="26" FontWeight="Black" Foreground="#2C3E50" Margin="25,20,0,25"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25,0,25,25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Form -->
                <StackPanel Margin="0,0,25,0">
                    <TextBlock Text="THANH TOÁN ĐIỆN TỬ" FontSize="14" FontWeight="Bold" Foreground="#7F8C8D" Margin="0,0,0,15"/>
                    
                    <materialDesign:Card UniformCornerRadius="16" Padding="35" Background="White">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <Border Background="#E8F5E9" CornerRadius="12" Padding="12" Margin="0,0,15,0">
                                    <materialDesign:PackIcon Kind="QrcodeScan" Width="32" Height="32" Foreground="#2E7D32" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Tích hợp VietQR" FontWeight="Black" FontSize="22" Foreground="#2C3E50"/>
                                    <TextBlock Text="Tự động tạo mã QR chính xác số tiền cho mỗi đơn hàng." Foreground="#7F8C8D" FontSize="14" Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Separator Margin="0,20,0,30" Background="#F1F3F4"/>

                            <ComboBox x:Name="cboBank" materialDesign:HintAssist.Hint="Ngân hàng thụ hưởng" Style="{StaticResource MaterialDesignFloatingHintComboBox}" FontSize="16" Margin="0,0,0,35" DisplayMemberPath="DisplayName" SelectedValuePath="bin" SelectionChanged="UpdatePreview"/>
                            
                            <TextBox x:Name="txtAccountNo" materialDesign:HintAssist.Hint="Số tài khoản" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="16" Margin="0,0,0,35" TextChanged="UpdatePreview"/>
                            
                            <TextBox x:Name="txtAccountName" materialDesign:HintAssist.Hint="Tên chủ tài khoản" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="16" Margin="0,0,0,45" TextChanged="UpdatePreview"/>

                            <Button Content="LƯU CẤU HÌNH" Background="#1A73E8" BorderThickness="0" Height="50" FontWeight="Bold" FontSize="15" Click="btnLuuVietQR_Click" materialDesign:ButtonAssist.CornerRadius="25" HorizontalAlignment="Left" Padding="40,0">
                                <Button.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.2" Color="#1A73E8"/>
                                </Button.Effect>
                            </Button>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>

                <!-- Right: Live Preview -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="XEM TRƯỚC MÃ QR" FontSize="14" FontWeight="Bold" Foreground="#7F8C8D" Margin="0,0,0,15"/>
                    <materialDesign:Card UniformCornerRadius="24" Background="#F8F9FA" BorderBrush="#E4E7EB" BorderThickness="1" MaxWidth="350">
                        <StackPanel Margin="0,0,0,30">
                            <!-- Mock Phone Header -->
                            <Border Background="#2C3E50" CornerRadius="24,24,0,0" Padding="15">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="ShieldCheck" Foreground="#2ECC71" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Mã QR Thanh Toán" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="16" Margin="30,40,30,25" Padding="15">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.08"/>
                                </Border.Effect>
                                <Grid Height="250" Width="250">
                                    <TextBlock x:Name="txtNoPreview" Text="Nhập thông tin bên trái để&#x0a;xem trước mã QR" Foreground="#BDC3C7" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Image x:Name="imgQRPreview" Stretch="Uniform"/>
                                </Grid>
                            </Border>

                            <TextBlock x:Name="lblPreviewName" Text="NGUYEN VAN A" FontWeight="Black" FontSize="20" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,8" Visibility="Collapsed"/>
                            <TextBlock x:Name="lblPreviewBank" Text="MB Bank - 123456789" FontSize="15" Foreground="#7F8C8D" HorizontalAlignment="Center" Visibility="Collapsed"/>
                            
                            <Border x:Name="brdPreviewAmount" Background="#E8F5E9" CornerRadius="8" Padding="15,6" HorizontalAlignment="Center" Margin="0,15,0,0" Visibility="Collapsed">
                                <TextBlock Text="Số tiền: 100,000 đ" Foreground="#2E7D32" FontWeight="Bold" FontSize="14"/>
                            </Border>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
