<UserControl x:Class="GreenMart.UserControls.ucNhanVien"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <!-- Main Content Area -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Quản lý nhân viên" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ComboBox x:Name="fboCV" materialDesign:HintAssist.Hint="Chức vụ" Width="130" Margin="0,0,10,0" Style="{StaticResource MaterialDesignFloatingHintComboBox}" SelectionChanged="Filter_Changed" VerticalAlignment="Center" FontSize="13">
                        <ComboBoxItem Content="Tất cả chức vụ"/>
                        <ComboBoxItem Content="Nhân viên bán hàng"/>
                        <ComboBoxItem Content="Nhân viên kho"/>
                        <ComboBoxItem Content="Quản lý"/>
                    </ComboBox>

                    <ComboBox x:Name="fboCH" materialDesign:HintAssist.Hint="Cửa hàng" Width="130" Margin="0,0,10,0" Style="{StaticResource MaterialDesignFloatingHintComboBox}" DisplayMemberPath="TenCH" SelectedValuePath="MaCH" SelectionChanged="Filter_Changed" VerticalAlignment="Center" FontSize="13"/>

                    <ComboBox x:Name="fboStatus" materialDesign:HintAssist.Hint="Trạng thái" Width="130" Margin="0,0,15,0" Style="{StaticResource MaterialDesignFloatingHintComboBox}" SelectionChanged="Filter_Changed" VerticalAlignment="Center" FontSize="13">
                        <ComboBoxItem Content="Tất cả trạng thái"/>
                        <ComboBoxItem Content="Đang làm việc"/>
                        <ComboBoxItem Content="Đã nghỉ việc"/>
                    </ComboBox>

                    <Border Background="#F1F3F4" CornerRadius="22" BorderBrush="#DADCE0" BorderThickness="1" Width="220" Height="44" Margin="0,0,15,0" VerticalAlignment="Center">
                        <Grid Margin="15,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="Magnify" Foreground="#5F6368" VerticalAlignment="Center" Width="20" Height="20"/>
                            <TextBox Grid.Column="1" x:Name="txtSearch" materialDesign:HintAssist.Hint="Tìm tên, mã..." materialDesign:TextFieldAssist.DecorationVisibility="Collapsed" BorderThickness="0" VerticalAlignment="Center" Background="Transparent" FontSize="14" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <Button Content="TÌM KIẾM" Background="#1A73E8" BorderThickness="0" Height="44" Padding="25,0" FontWeight="Bold" Click="btnTim_Click" materialDesign:ButtonAssist.CornerRadius="22" VerticalAlignment="Center"/>
                    <Button Content="＋ THÊM NV" Background="#34A853" BorderThickness="0" Height="44" Padding="15,0" Margin="10,0,0,0" FontWeight="Bold" Click="btnThem_Click" materialDesign:ButtonAssist.CornerRadius="22" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
            
            <materialDesign:Card Grid.Row="1" UniformCornerRadius="12" Padding="25" Margin="0,0,0,20" x:Name="fp" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="tft" Text="Thêm nhân viên" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,20"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        
                        <TextBox x:Name="txtMa" Grid.Column="0" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Mã NV" Style="{StaticResource MaterialDesignFloatingHintTextBox}" IsReadOnly="True" FontSize="14"/>
                        <TextBox x:Name="txtTen" Grid.Column="1" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Họ và tên" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14"/>
                        <ComboBox x:Name="cboCV" Grid.Column="2" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Chức vụ" Style="{StaticResource MaterialDesignFloatingHintComboBox}" FontSize="14"><ComboBoxItem Content="Nhân viên bán hàng"/><ComboBoxItem Content="Nhân viên kho"/><ComboBoxItem Content="Quản lý"/></ComboBox>
                        <ComboBox x:Name="cboGT" Grid.Column="3" Margin="0,0,0,20" materialDesign:HintAssist.Hint="Giới tính" Style="{StaticResource MaterialDesignFloatingHintComboBox}" FontSize="14"><ComboBoxItem Content="Nam"/><ComboBoxItem Content="Nữ"/></ComboBox>
                        
                        <DatePicker x:Name="dpNS" Grid.Row="1" Grid.Column="0" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Ngày sinh" Style="{StaticResource MaterialDesignFloatingHintDatePicker}" FontSize="14"/>
                        <TextBox x:Name="txtSDT" Grid.Row="1" Grid.Column="1" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Số điện thoại" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14" PreviewTextInput="NumberValidationTextBox" MaxLength="10"/>
                        <TextBox x:Name="txtDC" Grid.Row="1" Grid.Column="2" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Địa chỉ" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14"/>
                        <ComboBox x:Name="cboCH" Grid.Row="1" Grid.Column="3" Margin="0,0,0,20" materialDesign:HintAssist.Hint="Cửa hàng" Style="{StaticResource MaterialDesignFloatingHintComboBox}" DisplayMemberPath="TenCH" SelectedValuePath="MaCH" FontSize="14"/>
                        
                        <TextBox x:Name="txtTDN" Grid.Row="2" Grid.Column="0" Margin="0,0,20,0" materialDesign:HintAssist.Hint="Tên đăng nhập" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14"/>
                        <PasswordBox x:Name="txtMK" Grid.Row="2" Grid.Column="1" Margin="0,0,20,0" materialDesign:HintAssist.Hint="Mật khẩu (Để trống nếu giữ cũ)" Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" FontSize="14"/>
                        <ComboBox x:Name="cboStatus" Grid.Row="2" Grid.Column="2" Margin="0,0,20,0" materialDesign:HintAssist.Hint="Trạng thái" Style="{StaticResource MaterialDesignFloatingHintComboBox}" FontSize="14">
                            <ComboBoxItem Content="Đang làm việc"/>
                            <ComboBoxItem Content="Đã nghỉ việc"/>
                        </ComboBox>
                        
                        <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                            <Button Content="💾 Lưu" Background="#4CAF50" BorderThickness="0" Height="38" Padding="20,0" Click="btnLuu_Click"/>
                            <Button Content="✕" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#7F8C8D" BorderBrush="#BDC3C7" Height="38" Width="38" Padding="0" Margin="10,0,0,0" Click="btnHuy_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>
            
            <materialDesign:Card Grid.Row="2" UniformCornerRadius="12" Padding="10">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <DataGrid x:Name="dg" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" BorderThickness="0" GridLinesVisibility="Horizontal" RowHeight="55" FontSize="14" Background="Transparent" RowBackground="White" AlternatingRowBackground="#F9FAFB" HorizontalGridLinesBrush="#EEEEEE" VerticalGridLinesBrush="Transparent" SelectionMode="Single" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="MÃ" Binding="{Binding MaNV}" Width="0.8*" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="NHÂN VIÊN" Binding="{Binding HoTen}" Width="2*"/>
                            <DataGridTextColumn Header="CHỨC VỤ" Binding="{Binding ChucVu}" Width="1.5*"/>
                            <DataGridTextColumn Header="SỐ ĐIỆN THOẠI" Binding="{Binding SoDienThoai}" Width="1.5*"/>
                            <DataGridTextColumn Header="CỬA HÀNG" Binding="{Binding TenCH}" Width="1.5*"/>
                            <DataGridTemplateColumn Header="TRẠNG THÁI" Width="1.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#E8F5E9" CornerRadius="8" Padding="10,4" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding TrangThai}" Foreground="#2E7D32" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="THAO TÁC" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <Button Style="{StaticResource MaterialDesignIconButton}" Background="#E8F5E9" Foreground="#2E7D32" Width="32" Height="32" Padding="0" Click="btnView_Click" ToolTip="Xem chi tiết"><materialDesign:PackIcon Kind="Eye" Width="16" Height="16"/></Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}" Background="#E3F2FD" Foreground="#1565C0" Width="32" Height="32" Padding="0" Margin="8,0,0,0" Click="btnSua_Click" ToolTip="Sửa"><materialDesign:PackIcon Kind="Pencil" Width="16" Height="16"/></Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}" Background="#FFEBEE" Foreground="#C62828" Width="32" Height="32" Padding="0" Margin="8,0,0,0" Click="btnXoa_Click" ToolTip="Xóa"><materialDesign:PackIcon Kind="TrashCan" Width="16" Height="16"/></Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,5">
                        <Button Content="&lt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnPrev_Click"/>
                        <TextBlock x:Name="txtPage" Text="1 / 1" VerticalAlignment="Center" Margin="15,0" FontWeight="Bold" FontSize="14" Foreground="#7F8C8D"/>
                        <Button Content="&gt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnNext_Click"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!-- Chi tiết nhân viên Popup (Overlay) -->
        <Grid x:Name="popDetail" Visibility="Collapsed">
            <Border Background="#66000000" MouseDown="btnHuyDetail_Click"/>
            <materialDesign:Card UniformCornerRadius="16" Width="550" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <StackPanel>
                    <Grid Margin="0,0,0,25">
                        <TextBlock Text="HỒ SƠ NHÂN VIÊN" FontSize="18" FontWeight="Black" Foreground="#1B5E20"/>
                        <Button Style="{StaticResource MaterialDesignIconButton}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-15,-15,0" Click="btnHuyDetail_Click">
                            <materialDesign:PackIcon Kind="Close" Width="24" Height="24" Foreground="#7F8C8D"/>
                        </Button>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Border Width="100" Height="100" Background="#F4F6F8" CornerRadius="50" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <materialDesign:PackIcon Kind="Account" Width="60" Height="60" Foreground="#BDC3C7" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="pMa" Text="NV001" FontSize="13" Foreground="#7F8C8D" FontWeight="Bold"/>
                            <TextBlock x:Name="pTen" Text="Nguyễn Văn A" FontSize="24" FontWeight="Black" Foreground="#2C3E50" Margin="0,4,0,10"/>
                            
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#E3F2FD" CornerRadius="8" Padding="10,4" Margin="0,0,10,0">
                                    <TextBlock x:Name="pCV" Text="Quản lý" Foreground="#1565C0" FontWeight="Bold" FontSize="12"/>
                                </Border>
                                <Border Background="#E8F5E9" CornerRadius="8" Padding="10,4">
                                    <TextBlock x:Name="pStatus" Text="Đang làm việc" Foreground="#2E7D32" FontWeight="Bold" FontSize="12"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Separator Margin="0,25" Background="#EEEEEE"/>

                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                        
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="GIỚI TÍNH" FontSize="11" Foreground="#95A5A6" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock x:Name="pGT" Text="Nam" FontSize="15" FontWeight="SemiBold" Foreground="#34495E"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,0,20">
                            <TextBlock Text="NGÀY SINH" FontSize="11" Foreground="#95A5A6" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock x:Name="pNS" Text="01/01/1990" FontSize="15" FontWeight="SemiBold" Foreground="#34495E"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,0,0,20">
                            <TextBlock Text="SỐ ĐIỆN THOẠI" FontSize="11" Foreground="#95A5A6" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock x:Name="pSDT" Text="0123456789" FontSize="15" FontWeight="SemiBold" Foreground="#34495E"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,20">
                            <TextBlock Text="CỬA HÀNG" FontSize="11" Foreground="#95A5A6" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock x:Name="pCH" Text="GreenMart CH01" FontSize="15" FontWeight="SemiBold" Foreground="#34495E"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                            <TextBlock Text="ĐỊA CHỈ" FontSize="11" Foreground="#95A5A6" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock x:Name="pDC" Text="123 Đường ABC, Quận XYZ, TP.HCM" FontSize="15" FontWeight="SemiBold" Foreground="#34495E" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="Đóng hồ sơ" Margin="0,30,0,0" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#7F8C8D" BorderBrush="#BDC3C7" Height="45" Click="btnHuyDetail_Click"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
