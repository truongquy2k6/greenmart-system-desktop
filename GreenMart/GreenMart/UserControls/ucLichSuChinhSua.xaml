<UserControl x:Class="GreenMart.UserControls.ucLichSuChinhSua"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        
        <Grid Margin="0,0,0,20">
            <TextBlock Text="Lịch sử thay đổi dữ liệu" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <materialDesign:Card UniformCornerRadius="8" Padding="15,0" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="cboBang" Width="150" materialDesign:HintAssist.Hint="Tất cả các bảng" Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0,0,15,0" SelectionChanged="cboBang_SC">
                            <ComboBoxItem Content="Tất cả các bảng"/>
                            <ComboBoxItem Content="SanPham"/>
                            <ComboBoxItem Content="NhanVien"/>
                            <ComboBoxItem Content="KhachHang"/>
                            <ComboBoxItem Content="HoaDon"/>
                            <ComboBoxItem Content="Kho"/>
                            <ComboBoxItem Content="ChiTietKho"/>
                            <ComboBoxItem Content="LoaiSP"/>
                            <ComboBoxItem Content="NCC"/>
                            <ComboBoxItem Content="CuaHang"/>
                            <ComboBoxItem Content="KhuyenMai"/>
                        </ComboBox>
                        <TextBox x:Name="txtSearch" Width="180" materialDesign:HintAssist.Hint="Tìm nhân viên..." Style="{StaticResource MaterialDesignFloatingHintTextBox}" BorderThickness="0" VerticalAlignment="Center"/>
                    </StackPanel>
                </materialDesign:Card>
                <Button Content="TÌM KIẾM" Background="#4CAF50" BorderThickness="0" Height="45" Padding="15,0" Click="btnTim_Click"/>
            </StackPanel>
        </Grid>
        
        <materialDesign:Card Grid.Row="2" UniformCornerRadius="12" Padding="10">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <DataGrid x:Name="dg" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" BorderThickness="0" GridLinesVisibility="Horizontal" RowHeight="55" FontSize="14" Background="Transparent" RowBackground="White" AlternatingRowBackground="#F9FAFB" HorizontalGridLinesBrush="#EEEEEE" VerticalGridLinesBrush="Transparent" SelectionMode="Single" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="THỜI GIAN" Binding="{Binding ThoiGian, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="1.2*"/>
                        <DataGridTextColumn Header="NHÂN VIÊN" Binding="{Binding HoTen}" Width="1.5*" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="BẢNG DỮ LIỆU" Binding="{Binding TenBang}" Width="1*"/>
                        <DataGridTemplateColumn Header="HÀNH ĐỘNG" Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#E3F2FD" CornerRadius="8" Padding="10,4" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding HanhDong}" Foreground="#1565C0" FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="MÃ BẢN GHI" Binding="{Binding MaBanGhi}" Width="1*" FontWeight="Bold"/>
                        <DataGridTextColumn Header="NỘI DUNG CŨ" Binding="{Binding NoiDungCu}" Width="2*" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                    <Setter Property="Foreground" Value="#C62828"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="NỘI DUNG MỚI" Binding="{Binding NoiDungMoi}" Width="2*" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="CHI TIẾT" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}" Background="#F3E5F5" Foreground="#7B1FA2" Width="32" Height="32" Padding="0" Click="btnDetail_Click" ToolTip="Xem chi tiết thay đổi">
                                        <materialDesign:PackIcon Kind="Eye" Width="16" Height="16"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,5">
                    <Button Content="&lt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnPrev_Click"/>
                    <TextBlock x:Name="txtPage" Text="1 / 1" VerticalAlignment="Center" Margin="15,0" FontWeight="Bold" FontSize="14" Foreground="#7F8C8D"/>
                    <Button Content="&gt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnNext_Click"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Premium Detail Panel -->
        <materialDesign:Card Grid.Row="0" Grid.RowSpan="3" UniformCornerRadius="15" Padding="0" Margin="100,60" x:Name="detailPanel" Visibility="Collapsed" VerticalAlignment="Center" MaxWidth="900" Panel.ZIndex="100">
            <Border BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Background="#F8F9FA" Padding="25,20" CornerRadius="15,15,0,0" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="History" Width="28" Height="28" Foreground="#673AB7" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Chi tiết lịch sử thay đổi" FontWeight="Black" FontSize="20" Foreground="#2C3E50"/>
                                    <TextBlock x:Name="txtDetailSubtitle" Text="Bảng: SanPham | Mã bản ghi: SP001" FontSize="13" Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" Style="{StaticResource MaterialDesignIconButton}" Click="btnCloseDetail_Click" Foreground="#9E9E9E">
                                <materialDesign:PackIcon Kind="Close" Width="24" Height="24"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Content -->
                    <ScrollViewer Grid.Row="1" MaxHeight="550" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="25">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            
                            <!-- Old Content Card -->
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <Border Background="#FFF1F0" CornerRadius="10" Padding="15,8" Margin="0,0,0,12" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="MinusCircle" Foreground="#F5222D" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="DỮ LIỆU CŨ" FontWeight="Bold" Foreground="#F5222D" FontSize="13"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFFFFF" BorderBrush="#FFA39E" BorderThickness="1" CornerRadius="12" Padding="20" MinHeight="300">
                                    <TextBlock x:Name="txtOld" TextWrapping="Wrap" FontSize="15" Foreground="#595959" LineHeight="24" FontFamily="Consolas"/>
                                </Border>
                            </StackPanel>

                            <!-- New Content Card -->
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <Border Background="#F6FFED" CornerRadius="10" Padding="15,8" Margin="0,0,0,12" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="PlusCircle" Foreground="#52C41A" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="DỮ LIỆU MỚI" FontWeight="Bold" Foreground="#52C41A" FontSize="13"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFFFFF" BorderBrush="#B7EB8F" BorderThickness="1" CornerRadius="12" Padding="20" MinHeight="300">
                                    <TextBlock x:Name="txtNew" TextWrapping="Wrap" FontSize="15" Foreground="#595959" LineHeight="24" FontFamily="Consolas"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <!-- Footer -->
                    <Border Grid.Row="2" Background="#F8F9FA" Padding="25,15" CornerRadius="0,0,15,15" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="AccountCheck" Foreground="#607D8B" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20"/>
                                <TextBlock x:Name="txtInfo" Text="Người sửa: Admin | 15/05/2026 10:00:00" Foreground="#546E7A" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="ĐÓNG CỬA SỔ" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#7F8C8D" Click="btnCloseDetail_Click" Margin="0,0,10,0"/>
                                <Button Content="XÁC NHẬN" Background="#1A73E8" BorderThickness="0" Height="40" Padding="25,0" Click="btnCloseDetail_Click" materialDesign:ButtonAssist.CornerRadius="20"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            <materialDesign:Card.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="5" Opacity="0.3"/>
            </materialDesign:Card.Effect>
        </materialDesign:Card>
    </Grid>
</UserControl>
