<UserControl x:Class="GreenMart.UserControls.ucKhuyenMai"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        
        <Grid Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Quản lý khuyến mãi" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <ComboBox x:Name="fboLoai" materialDesign:HintAssist.Hint="Loại KM" Width="130" Margin="0,0,10,0" Style="{StaticResource MaterialDesignFloatingHintComboBox}" SelectionChanged="Filter_Changed" VerticalAlignment="Center" FontSize="13">
                    <ComboBoxItem Content="Tất cả loại"/>
                    <ComboBoxItem Content="Giảm theo %"/>
                    <ComboBoxItem Content="Giảm theo số tiền"/>
                </ComboBox>
                
                <ComboBox x:Name="fboStatus" materialDesign:HintAssist.Hint="Trạng thái" Width="130" Margin="0,0,15,0" Style="{StaticResource MaterialDesignFloatingHintComboBox}" SelectionChanged="Filter_Changed" VerticalAlignment="Center" FontSize="13">
                    <ComboBoxItem Content="Tất cả trạng thái"/>
                    <ComboBoxItem Content="Đang áp dụng"/>
                    <ComboBoxItem Content="Tạm dừng"/>
                    <ComboBoxItem Content="Hết hạn"/>
                </ComboBox>

                <Border Background="#F1F3F4" CornerRadius="22" BorderBrush="#DADCE0" BorderThickness="1" Width="220" Height="44" Margin="0,0,15,0" VerticalAlignment="Center">
                    <Grid Margin="15,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Magnify" Foreground="#5F6368" VerticalAlignment="Center" Width="20" Height="20"/>
                        <TextBox Grid.Column="1" x:Name="txtSearch" materialDesign:HintAssist.Hint="Tìm tên, mã..." materialDesign:TextFieldAssist.DecorationVisibility="Collapsed" BorderThickness="0" VerticalAlignment="Center" Background="Transparent" FontSize="14" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <Button Content="TÌM KIẾM" Background="#1A73E8" BorderThickness="0" Height="44" Padding="25,0" FontWeight="Bold" Click="btnTim_Click" materialDesign:ButtonAssist.CornerRadius="22" VerticalAlignment="Center"/>
                <Button Content="＋ THÊM KM" Background="#34A853" BorderThickness="0" Height="44" Padding="15,0" Margin="10,0,0,0" FontWeight="Bold" Click="btnThem_Click" materialDesign:ButtonAssist.CornerRadius="22" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
        
        <materialDesign:Card Grid.Row="1" UniformCornerRadius="12" Padding="25" Margin="0,0,0,20" x:Name="fp" Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="tft" Text="Thêm khuyến mãi" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,20"/>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    
                    <TextBox x:Name="txtMa" Grid.Column="0" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Mã KM" Style="{StaticResource MaterialDesignFloatingHintTextBox}" IsReadOnly="True" FontSize="14"/>
                    <TextBox x:Name="txtTen" Grid.Column="1" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Tên chương trình" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14"/>
                    <ComboBox x:Name="cboLoai" Grid.Column="2" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Loại khuyến mãi" Style="{StaticResource MaterialDesignFloatingHintComboBox}" FontSize="14"><ComboBoxItem Content="Giảm theo %"/><ComboBoxItem Content="Giảm theo số tiền"/></ComboBox>
                    <TextBox x:Name="txtGT" Grid.Column="3" Margin="0,0,0,20" materialDesign:HintAssist.Hint="Giá trị giảm" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14" PreviewTextInput="NumberValidationTextBox" MaxLength="12"/>
                    
                    <DatePicker x:Name="dpBD" Grid.Row="1" Grid.Column="0" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Từ ngày" Style="{StaticResource MaterialDesignFloatingHintDatePicker}" FontSize="14"/>
                    <DatePicker x:Name="dpKT" Grid.Row="1" Grid.Column="1" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Đến ngày" Style="{StaticResource MaterialDesignFloatingHintDatePicker}" FontSize="14"/>
                    <TextBox x:Name="txtDK" Grid.Row="1" Grid.Column="2" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Đơn tối thiểu (VNĐ)" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14" PreviewTextInput="NumberValidationTextBox" MaxLength="12"/>
                    <ComboBox x:Name="cboTrangThai" Grid.Row="1" Grid.Column="3" Margin="0,0,0,20" materialDesign:HintAssist.Hint="Trạng thái" Style="{StaticResource MaterialDesignFloatingHintComboBox}" FontSize="14"><ComboBoxItem Content="Đang áp dụng"/><ComboBoxItem Content="Tạm dừng"/><ComboBoxItem Content="Hết hạn"/></ComboBox>

                    <TextBox x:Name="txtMoTa" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,20,0" materialDesign:HintAssist.Hint="Mô tả chương trình" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14"/>
                    <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                        <Button Content="💾 Lưu" Background="#4CAF50" BorderThickness="0" Height="38" Padding="20,0" Click="btnLuu_Click"/>
                        <Button Content="✕ Hủy" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#7F8C8D" BorderBrush="#BDC3C7" Height="38" Padding="20,0" Margin="10,0,0,0" Click="btnHuy_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </materialDesign:Card>
        
        <materialDesign:Card Grid.Row="2" UniformCornerRadius="12" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <DataGrid x:Name="dg" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" BorderThickness="0" GridLinesVisibility="Horizontal" RowHeight="55" FontSize="14" Background="Transparent" RowBackground="White" AlternatingRowBackground="#F9FAFB" HorizontalGridLinesBrush="#EEEEEE" VerticalGridLinesBrush="Transparent" SelectionMode="Single" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="MÃ" Binding="{Binding MaKM}" Width="0.8*" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="TÊN CHƯƠNG TRÌNH" Binding="{Binding TenKM}" Width="2*"/>
                        <DataGridTextColumn Header="LOẠI" Binding="{Binding LoaiKM}" Width="1.5*"/>
                        <DataGridTextColumn Header="GIÁ TRỊ" Binding="{Binding GiaTri, StringFormat='{}{0:N0}'}" Width="1.2*" FontWeight="Bold" Foreground="#2E7D32"/>
                        <DataGridTextColumn Header="ĐƠN TỐI THIỂU" Binding="{Binding DieuKien, StringFormat='{}{0:N0}'}" Width="1.5*"/>
                        <DataGridTextColumn Header="TỪ NGÀY" Binding="{Binding NgayBatDau, StringFormat='{}{0:dd/MM/yyyy}'}" Width="1.2*"/>
                        <DataGridTextColumn Header="ĐẾN NGÀY" Binding="{Binding NgayKetThuc, StringFormat='{}{0:dd/MM/yyyy}'}" Width="1.2*"/>
                        <DataGridTextColumn Header="MÔ TẢ" Binding="{Binding MoTa}" Width="2*"/>
                        <DataGridTemplateColumn Header="TRẠNG THÁI" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="brdStatus" CornerRadius="8" Padding="10,4" HorizontalAlignment="Left" Background="#FFF3E0">
                                        <TextBlock x:Name="txtStatus" Text="{Binding TrangThai}" Foreground="#E65100" FontWeight="Bold"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding TrangThai}" Value="Đang áp dụng">
                                            <Setter TargetName="brdStatus" Property="Background" Value="#E8F5E9"/>
                                            <Setter TargetName="txtStatus" Property="Foreground" Value="#2E7D32"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TrangThai}" Value="Hết hạn">
                                            <Setter TargetName="brdStatus" Property="Background" Value="#FFEBEE"/>
                                            <Setter TargetName="txtStatus" Property="Foreground" Value="#C62828"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TrangThai}" Value="Tạm dừng">
                                            <Setter TargetName="brdStatus" Property="Background" Value="#ECEFF1"/>
                                            <Setter TargetName="txtStatus" Property="Foreground" Value="#455A64"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="THAO TÁC" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button Style="{StaticResource MaterialDesignIconButton}" Background="#E3F2FD" Foreground="#1565C0" Width="32" Height="32" Padding="0" Click="btnSua_Click"><materialDesign:PackIcon Kind="Pencil" Width="16" Height="16"/></Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}" Background="#FFEBEE" Foreground="#C62828" Width="32" Height="32" Padding="0" Margin="8,0,0,0" Click="btnXoa_Click"><materialDesign:PackIcon Kind="TrashCan" Width="16" Height="16"/></Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,5">
                    <Button Content="&lt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnPrev_Click"/>
                    <TextBlock x:Name="txtPage" Text="1 / 1" VerticalAlignment="Center" Margin="15,0" FontWeight="Bold" FontSize="14" Foreground="#7F8C8D"/>
                    <Button Content="&gt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnNext_Click"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
