<UserControl x:Class="GreenMart.UserControls.ucChiTietKho"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Chi tiết tồn kho" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Quản lý số lượng hàng hóa trong từng kho hàng" FontSize="13" Foreground="#7F8C8D" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <ComboBox x:Name="cboKho" materialDesign:HintAssist.Hint="— Tất cả kho —" 
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                          DisplayMemberPath="TenKho" SelectedValuePath="MaKho"
                          Width="200" Margin="0,0,15,0" SelectionChanged="cboKho_Changed" VerticalAlignment="Center" FontSize="13"/>

                <Border Background="#F1F3F4" CornerRadius="22" BorderBrush="#DADCE0" BorderThickness="1" Width="220" Height="44" Margin="0,0,15,0" VerticalAlignment="Center">
                    <Grid Margin="15,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Magnify" Foreground="#5F6368" VerticalAlignment="Center" Width="20" Height="20"/>
                        <TextBox Grid.Column="1" x:Name="txtSearch" materialDesign:HintAssist.Hint="Tìm sản phẩm..." materialDesign:TextFieldAssist.DecorationVisibility="Collapsed" BorderThickness="0" VerticalAlignment="Center" Background="Transparent" FontSize="14" Margin="8,0,0,0" KeyDown="txtSearch_KeyDown"/>
                    </Grid>
                </Border>

                <Button Content="TÌM KIẾM" Background="#1A73E8" BorderThickness="0" Height="44" Padding="25,0" FontWeight="Bold" Click="btnTim_Click" materialDesign:ButtonAssist.CornerRadius="22" VerticalAlignment="Center"/>
                <Button Content="＋ NHẬP HÀNG" Background="#34A853" BorderThickness="0" Height="44" Padding="20,0" Margin="10,0,0,0" FontWeight="Bold" Click="btnNhapHang_Click" materialDesign:ButtonAssist.CornerRadius="22" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Stats Overview Bar -->
        <materialDesign:Card Grid.Row="1" UniformCornerRadius="12" Padding="20,12" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Background="#E8F5E9" CornerRadius="8" Padding="15,8" Margin="0,0,20,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PackageVariant" Width="20" Height="20" Foreground="#2E7D32" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="txtTongSP" Text="0 loại SP" Foreground="#2E7D32" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#E3F2FD" CornerRadius="8" Padding="15,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Counter" Width="20" Height="20" Foreground="#1565C0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="txtTongSL" Text="0 đơn vị" Foreground="#1565C0" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </materialDesign:Card>

        <!-- Form nhập hàng -->
        <materialDesign:Card Grid.Row="2" UniformCornerRadius="12" Padding="20,15" Margin="0,0,0,12" x:Name="fpNhap" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtTitleNhap" Text="Nhập hàng:" FontWeight="Bold" FontSize="14" Foreground="#1565C0" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <ComboBox x:Name="cboKhoNhap" Grid.Column="1" materialDesign:HintAssist.Hint="Chọn kho" 
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                          DisplayMemberPath="TenKho" SelectedValuePath="MaKho" Margin="0,0,15,0"/>
                <ComboBox x:Name="cboSP" Grid.Column="2" materialDesign:HintAssist.Hint="Chọn sản phẩm" 
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                          DisplayMemberPath="TenSP" SelectedValuePath="MaSP" Margin="0,0,15,0"/>
                <TextBox x:Name="txtSL" Grid.Column="3" materialDesign:HintAssist.Hint="Số lượng" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,15,0" PreviewTextInput="NumberValidationTextBox" MaxLength="8"/>
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="💾 Lưu" Background="#4CAF50" BorderThickness="0" Height="36" Padding="15,0" Click="btnLuuNhap_Click"/>
                    <Button Content="✕" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#7F8C8D" 
                            BorderBrush="#BDC3C7" Height="36" Width="36" Padding="0" Margin="8,0,0,0" Click="btnHuyNhap_Click"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- DataGrid and Pagination -->
        <materialDesign:Card Grid.Row="3" UniformCornerRadius="12" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid x:Name="dg" AutoGenerateColumns="False" IsReadOnly="True" 
                      HeadersVisibility="Column" BorderThickness="0" GridLinesVisibility="Horizontal" 
                      RowHeight="55" FontSize="14" Background="Transparent" RowBackground="White" 
                      AlternatingRowBackground="#F9FAFB" HorizontalGridLinesBrush="#EEEEEE" 
                      VerticalGridLinesBrush="Transparent" SelectionMode="Single" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="KHO" Binding="{Binding TenKho}" Width="1.5*" FontWeight="Medium"/>
                        <DataGridTextColumn Header="MÃ SP" Binding="{Binding MaSP}" Width="0.8*" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="SẢN PHẨM" Binding="{Binding TenSP}" Width="2.5*"/>
                        <DataGridTemplateColumn Header="TỒN KHO" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="stockBorder" CornerRadius="10" Padding="12,4" HorizontalAlignment="Left" Background="#2E7D32">
                                        <TextBlock Text="{Binding SoLuong}" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2E7D32"/>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="THAO TÁC" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button Style="{StaticResource MaterialDesignIconButton}" 
                                            Background="#E3F2FD" Foreground="#1565C0" 
                                            Width="32" Height="32" Padding="0" Margin="0,0,8,0"
                                            Click="btnSuaCT_Click" ToolTip="Cập nhật số lượng">
                                            <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16"/>
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}" 
                                            Background="#FFEBEE" Foreground="#C62828" 
                                            Width="32" Height="32" Padding="0" 
                                            Click="btnXoaCT_Click" ToolTip="Xóa khỏi kho">
                                            <materialDesign:PackIcon Kind="TrashCan" Width="16" Height="16"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,5">
                    <Button Content="&lt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnPrev_Click"/>
                    <TextBlock x:Name="txtPage" Text="1 / 1" VerticalAlignment="Center" Margin="15,0" FontWeight="Bold" FontSize="14" Foreground="#7F8C8D"/>
                    <Button Content="&gt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnNext_Click"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
