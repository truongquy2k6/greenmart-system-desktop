<UserControl x:Class="GreenMart.UserControls.ucDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Tổng quan hoạt động" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
            <TextBlock x:Name="txtSubTitle" Text="" Foreground="#7F8C8D" FontSize="14" Margin="0,4,0,25"/>
            
            <!-- 4 Cards -->
            <UniformGrid Columns="4" Margin="0,0,0,25">
                <!-- Doanh thu -->
                <materialDesign:Card UniformCornerRadius="12" Padding="20" Margin="0,0,15,0" Background="White">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Doanh thu tháng" Foreground="#95A5A6" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtDoanhThu" Text="0 đ" FontSize="24" FontWeight="Black" Foreground="#2C3E50" Margin="0,8,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ArrowUp" Foreground="#4CAF50" Width="14" Height="14" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtDTTang" Text="12.5% so với tháng trước" Foreground="#4CAF50" FontSize="11" FontWeight="Bold" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="#E8F5E9" Width="40" Height="40" CornerRadius="20">
                            <materialDesign:PackIcon Kind="CashMultiple" Width="20" Height="20" Foreground="#2E7D32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </materialDesign:Card>
                
                <!-- Hóa đơn -->
                <materialDesign:Card UniformCornerRadius="12" Padding="20" Margin="0,0,15,0" Background="White">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Đơn hàng mới" Foreground="#95A5A6" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtSoDon" Text="0" FontSize="24" FontWeight="Black" Foreground="#2C3E50" Margin="0,8,0,4"/>
                            <TextBlock x:Name="txtDonTB" Text="TB: 0 đ/đơn" Foreground="#7F8C8D" FontSize="11" FontWeight="Medium"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="#E3F2FD" Width="40" Height="40" CornerRadius="20">
                            <materialDesign:PackIcon Kind="ReceiptText" Width="20" Height="20" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </materialDesign:Card>

                <!-- Khách hàng -->
                <materialDesign:Card UniformCornerRadius="12" Padding="20" Margin="0,0,15,0" Background="White">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Tổng khách hàng" Foreground="#95A5A6" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtSoKhach" Text="0" FontSize="24" FontWeight="Black" Foreground="#2C3E50" Margin="0,8,0,4"/>
                            <TextBlock Text="Đang hoạt động" Foreground="#7F8C8D" FontSize="11" FontWeight="Medium"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="#F3E5F5" Width="40" Height="40" CornerRadius="20">
                            <materialDesign:PackIcon Kind="AccountGroup" Width="20" Height="20" Foreground="#6A1B9A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </materialDesign:Card>

                <!-- Giá trị kho -->
                <materialDesign:Card UniformCornerRadius="12" Padding="20" Background="White">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Giá trị tồn kho" Foreground="#95A5A6" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtGiaTriKho" Text="0 đ" FontSize="24" FontWeight="Black" Foreground="#2C3E50" Margin="0,8,0,4"/>
                            <TextBlock x:Name="txtSapHet" Text="0 SP sắp hết hàng" Foreground="#E65100" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="#FFF3E0" Width="40" Height="40" CornerRadius="20">
                            <materialDesign:PackIcon Kind="Warehouse" Width="20" Height="20" Foreground="#E65100" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </materialDesign:Card>
            </UniformGrid>

            <!-- Middle Row: Charts & Low Stock -->
            <Grid Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Bar Chart -->
                <materialDesign:Card UniformCornerRadius="12" Padding="25" Margin="0,0,15,0">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Grid Margin="0,0,0,25">
                            <TextBlock Text="Doanh thu 7 ngày qua" FontWeight="Bold" FontSize="16" Foreground="#2C3E50"/>
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <TextBlock Text="Tổng tuần:" FontSize="13" Foreground="#95A5A6" VerticalAlignment="Bottom" Margin="0,0,5,2"/>
                                <TextBlock x:Name="txtTongTuan" Text="0 ₫" FontSize="18" FontWeight="Black" Foreground="#2E7D32"/>
                            </StackPanel>
                        </Grid>
                        <!-- Wave Chart -->
                        <Grid Grid.Row="1" Height="220" VerticalAlignment="Top">
                            <StackPanel VerticalAlignment="Stretch">
                                <Border BorderBrush="#F0F2F5" BorderThickness="0,0,0,1" Height="55"/>
                                <Border BorderBrush="#F0F2F5" BorderThickness="0,0,0,1" Height="55"/>
                                <Border BorderBrush="#F0F2F5" BorderThickness="0,0,0,1" Height="55"/>
                                <Border BorderBrush="#F0F2F5" BorderThickness="0,0,0,1" Height="55"/>
                            </StackPanel>

                            <!-- The Wave Path -->
                            <Path x:Name="wavePath" StrokeThickness="3" VerticalAlignment="Bottom">
                                <Path.Stroke>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#43A047" Offset="0"/>
                                        <GradientStop Color="#66BB6A" Offset="0.5"/>
                                        <GradientStop Color="#43A047" Offset="1"/>
                                    </LinearGradientBrush>
                                </Path.Stroke>
                                <Path.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#2043A047" Offset="0"/>
                                        <GradientStop Color="#0043A047" Offset="1"/>
                                    </LinearGradientBrush>
                                </Path.Fill>
                            </Path>

                            <!-- Data Points and Labels -->
                            <ItemsControl x:Name="chartPoints" SizeChanged="chartPoints_SizeChanged">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid VerticalAlignment="Stretch">
                                            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                                <!-- Value Label -->
                                                <TextBlock Text="{Binding Tooltip}" FontSize="10" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Center" Margin="0,0,0,4">
                                                    <TextBlock.RenderTransform>
                                                        <TranslateTransform Y="{Binding LabelY}"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                                
                                                <!-- Point Dot -->
                                                <Ellipse Width="8" Height="8" Fill="White" Stroke="#43A047" StrokeThickness="2">
                                                    <Ellipse.RenderTransform>
                                                        <TranslateTransform Y="{Binding LabelY}"/>
                                                    </Ellipse.RenderTransform>
                                                </Ellipse>

                                                <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#95A5A6" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Grid>
                </materialDesign:Card>
                
                <!-- Low Stock Products -->
                <materialDesign:Card Grid.Column="1" UniformCornerRadius="12" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Cảnh báo tồn kho" FontWeight="Bold" FontSize="16" Foreground="#C62828" Margin="0,0,0,20"/>
                        <ItemsControl x:Name="lowStockList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding TenSP}" FontSize="13" FontWeight="Bold" Foreground="#34495E"/>
                                            <TextBlock Text="{Binding DonViTinh}" FontSize="11" Foreground="#95A5A6"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#FFEBEE" CornerRadius="6" Padding="8,2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TonKho, StringFormat='{}Tồn: {0}'}" Foreground="#C62828" FontWeight="Bold" FontSize="12"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>

            <!-- Bottom Row: Top Sales & Top Customers -->
            <Grid Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Top Products -->
                <materialDesign:Card UniformCornerRadius="12" Padding="25" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Sản phẩm bán chạy" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,20"/>
                        <ItemsControl x:Name="topSPList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                        <Border Width="24" Height="24" CornerRadius="12" Background="#F1F8E9" HorizontalAlignment="Left"><materialDesign:PackIcon Kind="Star" Width="14" Height="14" Foreground="#4CAF50" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                        <TextBlock Grid.Column="1" Text="{Binding TenSP}" FontSize="13" FontWeight="Bold" Foreground="#34495E" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DaBan}" FontSize="13" FontWeight="Black" Foreground="#1B5E20" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Background="#F5F7FA" CornerRadius="4" Height="6" Margin="0,8,0,0">
                                            <Border CornerRadius="4" HorizontalAlignment="Left" Width="{Binding BarWidth}"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#81C784" Offset="0"/><GradientStop Color="#4CAF50" Offset="1"/></LinearGradientBrush></Border.Background></Border>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Top Customers -->
                <materialDesign:Card Grid.Column="1" UniformCornerRadius="12" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Khách hàng tiêu biểu" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,20"/>
                        <ItemsControl x:Name="topKHList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="18" Background="#E3F2FD"><materialDesign:PackIcon Kind="Account" Width="20" Height="20" Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding HoTen}" FontSize="13" FontWeight="Bold" Foreground="#34495E"/>
                                            <TextBlock Text="{Binding SoDon, StringFormat='{}{0} đơn hàng'}" FontSize="11" Foreground="#95A5A6"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding TongChi, StringFormat='{}{0:#,##0} ₫'}" FontSize="14" FontWeight="Bold" Foreground="#1565C0" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>

            <!-- Invoices Section -->
            <materialDesign:Card UniformCornerRadius="12" Padding="25" Margin="0,0,0,25">
                <StackPanel>
                    <TextBlock Text="Giao dịch gần đây" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,15"/>
                    <DataGrid x:Name="dgHoaDon" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" BorderThickness="0" GridLinesVisibility="Horizontal" RowHeight="50" FontSize="13" Background="Transparent" RowBackground="White" AlternatingRowBackground="#F9FAFB" HorizontalGridLinesBrush="#EEEEEE" VerticalGridLinesBrush="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="MÃ HD" Binding="{Binding MaHD}" Width="1*"/>
                            <DataGridTextColumn Header="THỜI GIAN" Binding="{Binding NgayLap, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="1.5*"/>
                            <DataGridTextColumn Header="KHÁCH HÀNG" Binding="{Binding TenKhachHang}" Width="3*"/>
                            <DataGridTextColumn Header="TỔNG TIỀN" Binding="{Binding TongTien, StringFormat='{}{0:#,##0} ₫'}" Width="1.5*" FontWeight="Bold" Foreground="#2E7D32"/>
                            <DataGridTemplateColumn Header="TRẠNG THÁI" Width="1.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12" Padding="12,4" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E8F5E9" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TrangThai}" Value="Đã hủy">
                                                            <Setter Property="Background" Value="#FFEBEE" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding TrangThai}" FontWeight="Bold" FontSize="12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#2E7D32" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding TrangThai}" Value="Đã hủy">
                                                                <Setter Property="Foreground" Value="#C62828" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
