<UserControl x:Class="GreenMart.UserControls.ucLichSuTruyCap"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header + Stats -->
        <Grid Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Lịch sử truy cập" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Theo dõi lịch sử đăng nhập / đăng xuất của nhân viên" FontSize="13" Foreground="#7F8C8D" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Thống kê nhanh -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
            <Border Background="#E8F5E9" CornerRadius="12" Margin="0,0,8,0" Padding="16,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <materialDesign:PackIcon Kind="Login" Width="20" Height="20" Foreground="#2E7D32" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Tổng lượt đăng nhập" Foreground="#4CAF50" FontSize="13"/>
                    </StackPanel>
                    <TextBlock x:Name="txtTongLuot" Text="0" FontSize="28" FontWeight="Black" Foreground="#1B5E20"/>
                </StackPanel>
            </Border>
            <Border Background="#E3F2FD" CornerRadius="12" Margin="4,0,4,0" Padding="16,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <materialDesign:PackIcon Kind="CalendarToday" Width="20" Height="20" Foreground="#1565C0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Hôm nay" Foreground="#1976D2" FontSize="13"/>
                    </StackPanel>
                    <TextBlock x:Name="txtHomNay" Text="0" FontSize="28" FontWeight="Black" Foreground="#0D47A1"/>
                </StackPanel>
            </Border>
            <Border Background="#FFF8E1" CornerRadius="12" Margin="4,0,4,0" Padding="16,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <materialDesign:PackIcon Kind="AccountGroup" Width="20" Height="20" Foreground="#F57F17" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Nhân viên khác nhau" Foreground="#F57F17" FontSize="13"/>
                    </StackPanel>
                    <TextBlock x:Name="txtNhanVienKhacNhau" Text="0" FontSize="28" FontWeight="Black" Foreground="#E65100"/>
                </StackPanel>
            </Border>
            <Border Background="#FCE4EC" CornerRadius="12" Margin="8,0,0,0" Padding="16,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <materialDesign:PackIcon Kind="ClockOutline" Width="20" Height="20" Foreground="#C62828" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Đang đăng nhập" Foreground="#E53935" FontSize="13"/>
                    </StackPanel>
                    <TextBlock x:Name="txtDangOnline" Text="0" FontSize="28" FontWeight="Black" Foreground="#B71C1C"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Filter Bar -->
        <materialDesign:Card Grid.Row="2" UniformCornerRadius="12" Padding="20,15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <DatePicker x:Name="dtTu" materialDesign:HintAssist.Hint="Từ ngày" Style="{StaticResource MaterialDesignOutlinedDatePicker}" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="18" Foreground="#9E9E9E"/>
                <DatePicker x:Name="dtDen" Grid.Column="2" materialDesign:HintAssist.Hint="Đến ngày" Style="{StaticResource MaterialDesignOutlinedDatePicker}" Margin="0,0,15,0"/>
                
                <TextBox x:Name="txtSearch" Grid.Column="3" materialDesign:HintAssist.Hint="Tìm nhân viên, IP..." materialDesign:TextFieldAssist.HasClearButton="True" materialDesign:TextFieldAssist.PrefixText="🔍 " Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="5,0,20,0" KeyDown="txtSearch_KeyDown" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Tìm kiếm" Background="#4CAF50" BorderThickness="0" Height="45" Padding="20,0" Margin="0,0,10,0" Click="btnTim_Click" materialDesign:ButtonAssist.CornerRadius="8"/>
                    <Button Content="Làm mới" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#607D8B" BorderBrush="#B0BEC5" Height="45" Padding="15,0" Click="btnReset_Click" materialDesign:ButtonAssist.CornerRadius="8"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="3" UniformCornerRadius="12" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <DataGrid x:Name="dg" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" 
                          BorderThickness="0" GridLinesVisibility="Horizontal" RowHeight="52" FontSize="14" 
                          Background="Transparent" RowBackground="White" AlternatingRowBackground="#F9FAFB" 
                          HorizontalGridLinesBrush="#EEEEEE" VerticalGridLinesBrush="Transparent" 
                          SelectionMode="Single" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="MÃ" Binding="{Binding MaTruyCap}" Width="0.8*" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="NHÂN VIÊN" Binding="{Binding HoTen}" Width="2*" FontWeight="Medium"/>
                        <DataGridTextColumn Header="MÃ NV" Binding="{Binding MaNV}" Width="0.8*" Foreground="#607D8B"/>
                        <DataGridTextColumn Header="ĐĂNG NHẬP" Binding="{Binding ThoiGianDangNhap, StringFormat='{}{0:dd/MM/yyyy HH:mm:ss}'}" Width="1.5*"/>
                        <DataGridTemplateColumn Header="ĐĂNG XUẤT" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" Margin="0,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding ThoiGianDangXuat, StringFormat='{}{0:dd/MM/yyyy HH:mm:ss}'}"/>
                                                <Setter Property="Foreground" Value="#37474F"/>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="ĐỊA CHỈ IP" Binding="{Binding DiaChiIP}" Width="1.2*" Foreground="#1565C0" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="THIẾT BỊ" Binding="{Binding ThietBi}" Width="2*" Foreground="#546E7A"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,5">
                    <Button Content="&lt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnPrev_Click"/>
                    <TextBlock x:Name="txtPage" Text="1 / 1" VerticalAlignment="Center" Margin="15,0" FontWeight="Bold" FontSize="14" Foreground="#7F8C8D"/>
                    <Button Content="&gt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnNext_Click"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
