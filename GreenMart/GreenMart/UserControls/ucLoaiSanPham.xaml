<UserControl x:Class="GreenMart.UserControls.ucLoaiSanPham"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Quản lý loại sản phẩm" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Border Background="#F1F3F4" CornerRadius="22" BorderBrush="#DADCE0" BorderThickness="1" Width="280" Height="44" Margin="0,0,15,0" VerticalAlignment="Center">
                    <Grid Margin="15,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Magnify" Foreground="#5F6368" VerticalAlignment="Center" Width="20" Height="20"/>
                        <TextBox Grid.Column="1" x:Name="txtSearch" materialDesign:HintAssist.Hint="Tìm tên loại, mã..." materialDesign:TextFieldAssist.DecorationVisibility="Collapsed" BorderThickness="0" VerticalAlignment="Center" Background="Transparent" FontSize="14" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <Button Content="TÌM KIẾM" Background="#1A73E8" BorderThickness="0" Height="44" Padding="25,0" FontWeight="Bold" Click="btnTim_Click" materialDesign:ButtonAssist.CornerRadius="22" VerticalAlignment="Center"/>
                <Button Content="＋ THÊM LOẠI" Background="#34A853" BorderThickness="0" Height="44" Padding="20,0" Margin="10,0,0,0" FontWeight="Bold" Click="btnThem_Click" materialDesign:ButtonAssist.CornerRadius="22" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
        
        <!-- Form -->
        <materialDesign:Card Grid.Row="1" UniformCornerRadius="12" Padding="25" Margin="0,0,0,20" x:Name="formPanel" Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="txtFormTitle" Text="Thêm loại sản phẩm" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,20"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="txtMa" Grid.Column="0" Margin="0,0,20,0" materialDesign:HintAssist.Hint="Mã loại sản phẩm" Style="{StaticResource MaterialDesignFloatingHintTextBox}" IsReadOnly="True" FontSize="14"/>
                    <TextBox x:Name="txtTen" Grid.Column="1" Margin="0,0,20,0" materialDesign:HintAssist.Hint="Tên loại sản phẩm" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14"/>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Content="💾 Lưu dữ liệu" Background="#4CAF50" BorderThickness="0" Height="38" Padding="20,0" Click="btnLuu_Click"/>
                        <Button Content="✕ Hủy" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#7F8C8D" BorderBrush="#BDC3C7" Height="38" Padding="20,0" Margin="10,0,0,0" Click="btnHuy_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </materialDesign:Card>
        
        <!-- Table and Pagination -->
        <materialDesign:Card Grid.Row="2" UniformCornerRadius="12" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid x:Name="dgData" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                      BorderThickness="0" GridLinesVisibility="Horizontal" RowHeight="55" FontSize="14"
                      Background="Transparent" RowBackground="White" AlternatingRowBackground="#F9FAFB"
                      HorizontalGridLinesBrush="#EEEEEE" VerticalGridLinesBrush="Transparent" SelectionMode="Single" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="MÃ LOẠI" Binding="{Binding MaLoai}" Width="1*" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="TÊN LOẠI SẢN PHẨM" Binding="{Binding TenLoai}" Width="3*" FontWeight="Medium"/>
                        <DataGridTemplateColumn Header="THAO TÁC" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button Style="{StaticResource MaterialDesignIconButton}" Background="#E3F2FD" Foreground="#1565C0" Width="32" Height="32" Padding="0" Click="btnSua_Click" ToolTip="Chỉnh sửa">
                                            <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16"/>
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}" Background="#FFEBEE" Foreground="#C62828" Width="32" Height="32" Padding="0" Margin="8,0,0,0" Click="btnXoa_Click" ToolTip="Xóa">
                                            <materialDesign:PackIcon Kind="TrashCan" Width="16" Height="16"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,5">
                    <Button Content="&lt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnPrev_Click"/>
                    <TextBlock x:Name="txtPage" Text="1 / 1" VerticalAlignment="Center" Margin="15,0" FontWeight="Bold" FontSize="14" Foreground="#7F8C8D"/>
                    <Button Content="&gt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnNext_Click"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
