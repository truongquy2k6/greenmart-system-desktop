<UserControl x:Class="GreenMart.UserControls.ucHoaDon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        
        <Grid Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Danh sách hóa đơn" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <DatePicker x:Name="dpTu" Width="140" materialDesign:HintAssist.Hint="Từ ngày" materialDesign:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignOutlinedDatePicker}" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="13"/>
                <DatePicker x:Name="dpDen" Width="140" materialDesign:HintAssist.Hint="Đến ngày" materialDesign:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignOutlinedDatePicker}" Margin="0,0,15,0" VerticalAlignment="Center" FontSize="13"/>
                
                <Border Background="#F1F3F4" CornerRadius="22" BorderBrush="#DADCE0" BorderThickness="1" Width="250" Height="44" Margin="0,0,15,0" VerticalAlignment="Center">
                    <Grid Margin="15,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Magnify" Foreground="#5F6368" VerticalAlignment="Center" Width="20" Height="20"/>
                        <TextBox Grid.Column="1" x:Name="txtSearch" materialDesign:HintAssist.Hint="Mã HD, tên KH..." materialDesign:TextFieldAssist.DecorationVisibility="Collapsed" BorderThickness="0" VerticalAlignment="Center" Background="Transparent" FontSize="14" Margin="8,0,0,0"/>
                    </Grid>
                </Border>
                
                <Button Content="TÌM KIẾM" Background="#1A73E8" BorderThickness="0" Height="44" Padding="25,0" FontWeight="Bold" Click="btnTim_Click" materialDesign:ButtonAssist.CornerRadius="22" VerticalAlignment="Center"/>
                <Button Content="XUẤT EXCEL" Background="#34A853" BorderThickness="0" Height="44" Padding="20,0" Margin="10,0,0,0" FontWeight="Bold" Click="btnXuatExcel_Click" materialDesign:ButtonAssist.CornerRadius="22" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions><ColumnDefinition Width="1.2*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            
            <materialDesign:Card UniformCornerRadius="12" Padding="10" Margin="0,0,15,0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <DataGrid x:Name="dg" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" BorderThickness="0" GridLinesVisibility="Horizontal" RowHeight="48" FontSize="14" Background="Transparent" RowBackground="White" AlternatingRowBackground="#F9FAFB" HorizontalGridLinesBrush="#EEEEEE" VerticalGridLinesBrush="Transparent" SelectionChanged="dg_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="MÃ HD" Binding="{Binding MaHD}" Width="90" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="NGÀY LẬP" Binding="{Binding NgayLap, StringFormat='{}{0:dd/MM/yyyy}'}" Width="120"/>
                            <DataGridTextColumn Header="KHÁCH HÀNG" Binding="{Binding TenKhachHang}" Width="*"/>
                            <DataGridTextColumn Header="TỔNG TIỀN" Binding="{Binding TongTien, StringFormat='{}{0:#,##0} đ'}" Width="140" Foreground="#2E7D32" FontWeight="Bold"/>
                            <DataGridTemplateColumn Header="TRẠNG THÁI" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="brd" CornerRadius="8" Padding="10,4" HorizontalAlignment="Left">
                                            <TextBlock x:Name="txt" Text="{Binding TrangThai}" FontWeight="Bold"/>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding TrangThai}" Value="Hoàn thành">
                                                <Setter TargetName="brd" Property="Background" Value="#E8F5E9"/>
                                                <Setter TargetName="txt" Property="Foreground" Value="#2E7D32"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TrangThai}" Value="Đã hủy">
                                                <Setter TargetName="brd" Property="Background" Value="#FFEBEE"/>
                                                <Setter TargetName="txt" Property="Foreground" Value="#C62828"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="THAO TÁC" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="🖨️ IN" Background="#FFF3E0" Foreground="#E65100" BorderThickness="0" Height="30" Padding="10,0" Margin="0,0,5,0" Click="btnInHD_Click"/>
                                            <Button Content="✕ HỦY" Background="#FFEBEE" Foreground="#C62828" BorderThickness="0" Height="30" Padding="10,0" Click="btnHuy_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding TrangThai}" Value="Đã hủy">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,5">
                        <Button Content="&lt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnPrev_Click"/>
                        <TextBlock x:Name="txtPage" Text="1 / 1" VerticalAlignment="Center" Margin="15,0" FontWeight="Bold" FontSize="14" Foreground="#7F8C8D"/>
                        <Button Content="&gt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnNext_Click"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
            
            <materialDesign:Card Grid.Column="1" UniformCornerRadius="12" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Info -->
                        <RowDefinition Height="*"/>    <!-- Items -->
                        <RowDefinition Height="Auto"/> <!-- Summary -->
                    </Grid.RowDefinitions>

                    <Border Background="#F8F9FA" Padding="20,15" CornerRadius="12,12,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Receipt" Width="24" Height="24" Foreground="#2C3E50" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="CHI TIẾT HÓA ĐƠN" FontWeight="Black" FontSize="16" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <Grid Grid.Row="1" Margin="20,15">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="txtSelectedMaHD" Text="Hóa đơn: ---" FontWeight="Bold" FontSize="15" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtSelectedNgay" Text="Ngày lập: ---" Foreground="#7F8C8D" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock x:Name="txtSelectedKhach" Text="Khách hàng: ---" FontWeight="Medium" FontSize="14" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtSelectedNhanVien" Text="Nhân viên: ---" Foreground="#7F8C8D" FontSize="13" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <DataGrid x:Name="dgCT" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" 
                              BorderThickness="0" GridLinesVisibility="Horizontal" RowHeight="45" FontSize="14" 
                              Background="Transparent" RowBackground="White" AlternatingRowBackground="#FDFDFD" 
                              HorizontalGridLinesBrush="#F1F1F1" VerticalGridLinesBrush="Transparent" Margin="20,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SẢN PHẨM" Binding="{Binding TenSP}" Width="*"/>
                            <DataGridTextColumn Header="ĐVT" Binding="{Binding DonViTinh}" Width="60" Foreground="#7F8C8D"/>
                            <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="50" FontWeight="Bold" ElementStyle="{StaticResource {x:Type TextBlock}}">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                        <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="ĐƠN GIÁ" Binding="{Binding DonGia, StringFormat='{}{0:#,##0}'}" Width="100"/>
                            <DataGridTextColumn Header="THÀNH TIỀN" Binding="{Binding ThanhTien, StringFormat='{}{0:#,##0}'}" Width="110" Foreground="#2E7D32" FontWeight="Bold"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="3" Background="#F8F9FA" Padding="25,20" CornerRadius="0,0,12,12" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Tạm tính" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="txtSelectedSubtotal" Text="0 đ" HorizontalAlignment="Right" FontWeight="Medium"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Giảm giá" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="txtSelectedDiscount" Text="0 đ" HorizontalAlignment="Right" Foreground="#C62828" FontWeight="Medium"/>
                            </Grid>
                            <Separator Background="#E0E0E0" Margin="0,0,0,15"/>
                            <Grid>
                                <TextBlock Text="TỔNG TIỀN" FontWeight="Bold" FontSize="18" Foreground="#2C3E50"/>
                                <TextBlock x:Name="txtSelectedTong" Text="0 đ" HorizontalAlignment="Right" FontSize="22" FontWeight="Black" Foreground="#2E7D32"/>
                            </Grid>
                            <TextBlock x:Name="txtSelectedPTTT" Text="Phương thức: ---" Foreground="#7F8C8D" FontSize="12" Margin="0,10,0,0" HorizontalAlignment="Right" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
