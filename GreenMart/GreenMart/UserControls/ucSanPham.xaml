<UserControl x:Class="GreenMart.UserControls.ucSanPham"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <!-- Main Content Area -->
        <Grid x:Name="mainContent">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Visibility, ElementName=popDetail}" Value="Visible">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="15" KernelType="Gaussian"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Sản phẩm" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center" Margin="0,0,20,10"/>
                
                <WrapPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ComboBox x:Name="cboFilterLoai" Width="130" Margin="0,0,10,10" materialDesign:HintAssist.Hint="Loại SP" Style="{StaticResource MaterialDesignFloatingHintComboBox}" SelectionChanged="Filter_SelectionChanged" DisplayMemberPath="TenLoai" SelectedValuePath="MaLoai"/>
                    <ComboBox x:Name="cboFilterNCC" Width="130" Margin="0,0,10,10" materialDesign:HintAssist.Hint="Nhà cung cấp" Style="{StaticResource MaterialDesignFloatingHintComboBox}" SelectionChanged="Filter_SelectionChanged" DisplayMemberPath="TenNCC" SelectedValuePath="MaNCC"/>
                    <ComboBox x:Name="cboFilterDVT" Width="90" Margin="0,0,10,10" materialDesign:HintAssist.Hint="ĐVT" Style="{StaticResource MaterialDesignFloatingHintComboBox}" SelectionChanged="Filter_SelectionChanged" DisplayMemberPath="DonViTinh" SelectedValuePath="DonViTinh"/>
                    <ComboBox x:Name="cboFilterTrangThai" Width="130" Margin="0,0,10,10" materialDesign:HintAssist.Hint="Trạng thái" Style="{StaticResource MaterialDesignFloatingHintComboBox}" SelectionChanged="Filter_SelectionChanged">
                        <ComboBoxItem Content="-- Tất cả --" IsSelected="True"/>
                        <ComboBoxItem Content="Đang kinh doanh"/>
                        <ComboBoxItem Content="Ngừng kinh doanh"/>
                    </ComboBox>
                    
                    <Border Background="#F1F3F4" CornerRadius="20" BorderBrush="#DADCE0" BorderThickness="1" Width="200" Height="40" Margin="0,0,10,10" VerticalAlignment="Center">
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="Magnify" Foreground="#5F6368" VerticalAlignment="Center" Width="20" Height="20"/>
                            <TextBox Grid.Column="1" x:Name="txtSearch" materialDesign:HintAssist.Hint="Tìm kiếm..." materialDesign:TextFieldAssist.DecorationVisibility="Collapsed" BorderThickness="0" VerticalAlignment="Center" Background="Transparent" FontSize="14" Margin="5,0,0,0"/>
                        </Grid>
                    </Border>

                    <Button Content="TÌM" Background="#1A73E8" BorderThickness="0" Height="40" Padding="15,0" Margin="0,0,10,10" FontWeight="Bold" Click="btnTim_Click" materialDesign:ButtonAssist.CornerRadius="20" VerticalAlignment="Center"/>
                    <Button Content="ĐỒNG BỘ KHO" Background="#F2994A" BorderThickness="0" Height="40" Padding="15,0" Margin="0,0,10,10" FontWeight="Bold" Click="btnDongBo_Click" materialDesign:ButtonAssist.CornerRadius="20" VerticalAlignment="Center"/>
                    <Button Content="＋ THÊM" Background="#34A853" BorderThickness="0" Height="40" Padding="15,0" Margin="0,0,0,10" FontWeight="Bold" Click="btnThem_Click" materialDesign:ButtonAssist.CornerRadius="20" VerticalAlignment="Center"/>
                </WrapPanel>
            </Grid>
            
            <materialDesign:Card Grid.Row="1" UniformCornerRadius="12" Padding="25" Margin="0,0,0,20" x:Name="fp" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="tft" Text="Thêm sản phẩm" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,20"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        
                        <TextBox x:Name="txtMa" Grid.Column="0" Margin="0,0,15,20" materialDesign:HintAssist.Hint="Mã SP" Style="{StaticResource MaterialDesignFloatingHintTextBox}" IsReadOnly="True" FontSize="14"/>
                        <TextBox x:Name="txtTen" Grid.Column="1" Margin="0,0,15,20" materialDesign:HintAssist.Hint="Tên sản phẩm" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14"/>
                        <TextBox x:Name="txtGia" Grid.Column="2" Margin="0,0,15,20" materialDesign:HintAssist.Hint="Đơn giá" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14" PreviewTextInput="NumberValidationTextBox"/>
                        <TextBox x:Name="txtDVT" Grid.Column="3" Margin="0,0,15,20" materialDesign:HintAssist.Hint="ĐVT" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14"/>
                        <ComboBox x:Name="cboTrangThai" Grid.Column="4" Margin="0,0,0,20" materialDesign:HintAssist.Hint="Trạng thái" Style="{StaticResource MaterialDesignFloatingHintComboBox}" FontSize="14"><ComboBoxItem Content="Đang kinh doanh"/><ComboBoxItem Content="Ngừng kinh doanh"/></ComboBox>

                        <ComboBox x:Name="cboLoai" Grid.Row="1" Grid.Column="0" Margin="0,0,15,20" materialDesign:HintAssist.Hint="Loại sản phẩm" Style="{StaticResource MaterialDesignFloatingHintComboBox}" DisplayMemberPath="TenLoai" SelectedValuePath="MaLoai" FontSize="14"/>
                        <ComboBox x:Name="cboNCC" Grid.Row="1" Grid.Column="1" Margin="0,0,15,20" materialDesign:HintAssist.Hint="Nhà cung cấp" Style="{StaticResource MaterialDesignFloatingHintComboBox}" DisplayMemberPath="TenNCC" SelectedValuePath="MaNCC" FontSize="14"/>
                        <TextBox x:Name="txtMoTa" Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,0,15,20" materialDesign:HintAssist.Hint="Mô tả" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14"/>
                        
                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="50" Height="50" CornerRadius="8" Background="#F4F6F8" Margin="0,0,15,0" BorderBrush="#E0E0E0" BorderThickness="1" ClipToBounds="True">
                                <Image x:Name="imgPreview" Stretch="UniformToFill" />
                            </Border>
                            <Button Content="📷 Chọn hình ảnh" Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center" Click="btnChonAnh_Click"/>
                            <TextBlock x:Name="txtTrangThaiAnh" Text="" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#7F8C8D" FontStyle="Italic"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                            <Button Content="💾 Lưu" Background="#4CAF50" BorderThickness="0" Height="38" Padding="15,0" Click="btnLuu_Click"/>
                            <Button Content="✕" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#7F8C8D" BorderBrush="#BDC3C7" Height="38" Width="38" Padding="0" Margin="10,0,0,0" Click="btnHuy_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>
            
            <materialDesign:Card Grid.Row="2" UniformCornerRadius="12" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="icProducts">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <materialDesign:Card Width="280" Margin="10" UniformCornerRadius="12" Background="White">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="200"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- Image -->
                                            <Border CornerRadius="12,12,0,0" ClipToBounds="True" Background="#F4F6F8">
                                                <Grid>
                                                    <materialDesign:PackIcon Kind="ImageOutline" Width="48" Height="48" Foreground="#BDC3C7" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <Image Source="{Binding HinhAnh}" Stretch="UniformToFill"/>
                                                    <!-- Status Badge -->
                                                    <Border Padding="8,4" CornerRadius="8" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#E8F5E9" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TrangThai}" Value="Ngừng kinh doanh">
                                                                        <Setter Property="Background" Value="#FFEBEE" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding TrangThai}" FontWeight="Bold" FontSize="11">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#2E7D32" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding TrangThai}" Value="Ngừng kinh doanh">
                                                                            <Setter Property="Foreground" Value="#C62828" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            
                                            <!-- Info -->
                                            <StackPanel Grid.Row="1" Margin="15">
                                                <TextBlock Text="{Binding TenLoai}" FontSize="12" Foreground="#7F8C8D" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding TenSP}" FontSize="16" FontWeight="Black" Foreground="#2C3E50" Margin="0,4,0,8" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding DonGia, StringFormat='{}{0:#,##0} đ'}" FontSize="18" Foreground="#2E7D32" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding MaSP}" FontSize="12" Foreground="#BDC3C7" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            
                                            <!-- Actions -->
                                            <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#F0F0F0" Padding="15,10" Background="#FAFAFA" CornerRadius="0,0,12,12">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Style="{StaticResource MaterialDesignIconButton}" Background="#E8F5E9" Foreground="#2E7D32" Width="32" Height="32" Padding="0" Click="btnView_Click" ToolTip="Xem chi tiết"><materialDesign:PackIcon Kind="Eye" Width="16" Height="16"/></Button>
                                                    <Button Style="{StaticResource MaterialDesignIconButton}" Background="#E3F2FD" Foreground="#1565C0" Width="32" Height="32" Padding="0" Margin="8,0,0,0" Click="btnSua_Click" ToolTip="Sửa"><materialDesign:PackIcon Kind="Pencil" Width="16" Height="16"/></Button>
                                                    <Button Style="{StaticResource MaterialDesignIconButton}" Background="#FFEBEE" Foreground="#C62828" Width="32" Height="32" Padding="0" Margin="8,0,0,0" Click="btnXoa_Click" ToolTip="Xóa"><materialDesign:PackIcon Kind="TrashCan" Width="16" Height="16"/></Button>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,5">
                        <Button Content="&lt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnPrev_Click"/>
                        <TextBlock x:Name="txtPage" Text="1 / 1" VerticalAlignment="Center" Margin="15,0" FontWeight="Bold" FontSize="14" Foreground="#7F8C8D"/>
                        <Button Content="&gt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnNext_Click"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!-- Chi tiết sản phẩm Popup (Overlay) -->
        <Grid x:Name="popDetail" Visibility="Collapsed" Margin="-25">
            <Border Background="#99000000" MouseDown="btnHuyDetail_Click"/>
            <materialDesign:Card UniformCornerRadius="16" Width="600" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <StackPanel>
                    <Grid Margin="0,0,0,25">
                        <TextBlock Text="CHI TIẾT SẢN PHẨM" FontSize="18" FontWeight="Black" Foreground="#1B5E20"/>
                        <Button Style="{StaticResource MaterialDesignIconButton}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-15,-15,0" Click="btnHuyDetail_Click">
                            <materialDesign:PackIcon Kind="Close" Width="24" Height="24" Foreground="#7F8C8D"/>
                        </Button>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Border Background="#F4F6F8" CornerRadius="12" Height="180" Margin="0,0,25,0" ClipToBounds="True">
                            <Grid>
                                <materialDesign:PackIcon Kind="ImageOutline" Width="48" Height="48" Foreground="#BDC3C7" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image x:Name="pImgDetail" Stretch="UniformToFill" />
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="pMa" Text="SP001" FontSize="13" Foreground="#7F8C8D" FontWeight="Bold"/>
                            <TextBlock x:Name="pTen" Text="Tên sản phẩm" FontSize="22" FontWeight="Black" Foreground="#2C3E50" Margin="0,4,0,10"/>
                            
                            <Border Background="#E8F5E9" HorizontalAlignment="Left" CornerRadius="8" Padding="10,4" Margin="0,0,0,15">
                                <TextBlock x:Name="pStatus" Text="Đang kinh doanh" Foreground="#2E7D32" FontWeight="Bold" FontSize="12"/>
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="ĐƠN GIÁ" FontSize="11" Foreground="#95A5A6" FontWeight="Bold"/>
                                    <TextBlock x:Name="pGia" Text="0 đ" FontSize="18" FontWeight="Bold" Foreground="#2E7D32"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="ĐƠN VỊ TÍNH" FontSize="11" Foreground="#95A5A6" FontWeight="Bold"/>
                                    <TextBlock x:Name="pDVT" Text="-" FontSize="18" FontWeight="Bold" Foreground="#34495E"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,25,0,0">
                        <TextBlock Text="THÔNG TIN CHI TIẾT" FontSize="12" Foreground="#95A5A6" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                            
                            <TextBlock Text="Loại SP:" Foreground="#7F8C8D" Margin="0,0,0,8"/>
                            <TextBlock x:Name="pLoai" Text="-" Grid.Column="1" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <TextBlock Text="Nhà cung cấp:" Grid.Row="1" Foreground="#7F8C8D" Margin="0,0,0,8"/>
                            <TextBlock x:Name="pNCC" Text="-" Grid.Row="1" Grid.Column="1" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <TextBlock Text="Mô tả:" Grid.Row="2" Foreground="#7F8C8D"/>
                            <TextBlock x:Name="pMoTa" Text="-" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" MaxHeight="60"/>
                        </Grid>
                    </StackPanel>

                    <materialDesign:Card Background="#F8F9FA" UniformCornerRadius="12" Margin="0,25,0,0" Padding="15">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Warehouse" Width="20" Height="20" Foreground="#1B5E20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Tình trạng tồn kho" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="pTon" Text="Tổng tồn: 0" HorizontalAlignment="Right" FontWeight="Black" Foreground="#1B5E20" VerticalAlignment="Center"/>
                        </Grid>
                    </materialDesign:Card>

                    <Button Content="Đóng" Margin="0,25,0,0" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#7F8C8D" BorderBrush="#BDC3C7" Height="45" Click="btnHuyDetail_Click"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
