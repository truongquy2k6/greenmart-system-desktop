<UserControl x:Class="GreenMart.UserControls.ucKhachHang"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        
        <Grid Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Quản lý khách hàng" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <DatePicker x:Name="dpTu" Width="140" materialDesign:HintAssist.Hint="Từ ngày" materialDesign:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignOutlinedDatePicker}" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="13"/>
                <DatePicker x:Name="dpDen" Width="140" materialDesign:HintAssist.Hint="Đến ngày" materialDesign:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignOutlinedDatePicker}" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="13"/>
                
                <ComboBox x:Name="cboStatus" Width="120" materialDesign:HintAssist.Hint="Trạng thái" Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0,0,15,0" VerticalAlignment="Center" FontSize="13">
                    <ComboBoxItem Content="Tất cả"/>
                    <ComboBoxItem Content="Hoạt động"/>
                    <ComboBoxItem Content="Khóa"/>
                </ComboBox>

                <Border Background="#F1F3F4" CornerRadius="22" BorderBrush="#DADCE0" BorderThickness="1" Width="250" Height="44" Margin="0,0,15,0" VerticalAlignment="Center">
                    <Grid Margin="15,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Magnify" Foreground="#5F6368" VerticalAlignment="Center" Width="20" Height="20"/>
                        <TextBox Grid.Column="1" x:Name="txtSearch" materialDesign:HintAssist.Hint="Tìm tên, SĐT..." materialDesign:TextFieldAssist.DecorationVisibility="Collapsed" BorderThickness="0" VerticalAlignment="Center" Background="Transparent" FontSize="14" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <Button Content="TÌM KIẾM" Background="#1A73E8" BorderThickness="0" Height="44" Padding="25,0" FontWeight="Bold" Click="btnTim_Click" materialDesign:ButtonAssist.CornerRadius="22" VerticalAlignment="Center"/>
                <Button Content="＋ THÊM" Background="#34A853" BorderThickness="0" Height="44" Padding="20,0" Margin="10,0,0,0" FontWeight="Bold" Click="btnThem_Click" materialDesign:ButtonAssist.CornerRadius="22" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
        
        <materialDesign:Card Grid.Row="1" UniformCornerRadius="12" Padding="25" Margin="0,0,0,20" x:Name="formPanel" Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="txtFormTitle" Text="Thêm khách hàng" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,20"/>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBox x:Name="txtMa" Grid.Column="0" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Mã khách hàng" Style="{StaticResource MaterialDesignFloatingHintTextBox}" IsReadOnly="True" FontSize="14"/>
                    <TextBox x:Name="txtTen" Grid.Column="1" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Họ và tên" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14"/>
                    <TextBox x:Name="txtSDT" Grid.Column="2" Margin="0,0,0,20" materialDesign:HintAssist.Hint="Số điện thoại" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14" PreviewTextInput="NumberValidationTextBox" MaxLength="10"/>
                    
                    <TextBox x:Name="txtDiaChi" Grid.Row="1" Grid.Column="0" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Địa chỉ" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14"/>
                    <TextBox x:Name="txtEmail" Grid.Row="1" Grid.Column="1" Margin="0,0,20,20" materialDesign:HintAssist.Hint="Email" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="14"/>

                    <Grid Grid.Row="1" Grid.Column="2" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtDiem" Margin="0,0,15,0" materialDesign:HintAssist.Hint="Điểm tích lũy" Style="{StaticResource MaterialDesignFloatingHintTextBox}" IsReadOnly="True" FontSize="14"/>
                        <ComboBox x:Name="cboFormStatus" Grid.Column="1" Width="130" materialDesign:HintAssist.Hint="Trạng thái" Style="{StaticResource MaterialDesignFloatingHintComboBox}" FontSize="14">
                            <ComboBoxItem Content="Hoạt động"/>
                            <ComboBoxItem Content="Khóa"/>
                        </ComboBox>
                    </Grid>
                    
                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="💾 LƯU DỮ LIỆU" Background="#4CAF50" BorderThickness="0" Height="40" Padding="25,0" FontWeight="Bold" Click="btnLuu_Click" materialDesign:ButtonAssist.CornerRadius="8"/>
                        <Button Content="✕ HỦY" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#7F8C8D" BorderBrush="#BDC3C7" Height="40" Padding="25,0" Margin="15,0,0,0" Click="btnHuy_Click" materialDesign:ButtonAssist.CornerRadius="8"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </materialDesign:Card>
        
        <materialDesign:Card Grid.Row="2" UniformCornerRadius="12" Padding="10">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <DataGrid x:Name="dgData" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" BorderThickness="0" GridLinesVisibility="Horizontal" RowHeight="48" FontSize="14" Background="Transparent" RowBackground="White" AlternatingRowBackground="#F9FAFB" HorizontalGridLinesBrush="#EEEEEE" VerticalGridLinesBrush="Transparent" SelectionMode="Single" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="MÃ" Binding="{Binding MaKH}" Width="0.8*" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="KHÁCH HÀNG" Binding="{Binding HoTen}" Width="2*"/>
                        <DataGridTextColumn Header="SỐ ĐIỆN THOẠI" Binding="{Binding SoDienThoai}" Width="1.5*"/>
                        <DataGridTextColumn Header="ĐỊA CHỈ" Binding="{Binding DiaChi}" Width="2*"/>
                        <DataGridTemplateColumn Header="ĐIỂM" Width="0.8*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#E3F2FD" CornerRadius="8" Padding="10,4" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding DiemTichLuy}" Foreground="#1565C0" FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="TRẠNG THÁI" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="brd" CornerRadius="8" Padding="10,4" HorizontalAlignment="Left">
                                        <TextBlock x:Name="txt" Text="{Binding TrangThai}" FontWeight="Bold" FontSize="12"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding TrangThai}" Value="Hoạt động">
                                            <Setter TargetName="brd" Property="Background" Value="#E8F5E9"/>
                                            <Setter TargetName="txt" Property="Foreground" Value="#2E7D32"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TrangThai}" Value="Khóa">
                                            <Setter TargetName="brd" Property="Background" Value="#FFEBEE"/>
                                            <Setter TargetName="txt" Property="Foreground" Value="#C62828"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="THAO TÁC" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button Style="{StaticResource MaterialDesignIconButton}" Background="#E3F2FD" Foreground="#1565C0" Width="32" Height="32" Padding="0" Click="btnSua_Click"><materialDesign:PackIcon Kind="Pencil" Width="16" Height="16"/></Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}" Background="#FFEBEE" Foreground="#C62828" Width="32" Height="32" Padding="0" Margin="8,0,0,0" Click="btnXoa_Click"><materialDesign:PackIcon Kind="TrashCan" Width="16" Height="16"/></Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,5">
                    <Button Content="&lt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnPrev_Click"/>
                    <TextBlock x:Name="txtPage" Text="1 / 1" VerticalAlignment="Center" Margin="15,0" FontWeight="Bold" FontSize="14" Foreground="#7F8C8D"/>
                    <Button Content="&gt;" Width="35" Height="35" Padding="0" Style="{StaticResource MaterialDesignOutlinedButton}" Click="btnNext_Click"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
